{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": false,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "./src/*"
      ]
    }
  },
  "include": [
    "app/**/*.ts",
    "app/**/*.tsx",
    "src/**/*.ts",
    "src/**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts",
    "nativewind-env.d.ts"
  ],
  "exclude": [
    "node_modules",
    "supabase",
    "src/main.tsx",
    "src/App.tsx",
    "src/module/**",
    "src/components/**",
    "src/pages/**",
    "src/lib/**",
    "src/hooks/useMIAChat.ts",
    "src/hooks/usePushNotifications.ts",
    "src/hooks/use-toast.ts",
    "src/utils/geo.ts"
  ]
}